# API Keys for LLM services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Ollama configuration (for local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Retry settings
GEMINI_RETRY_DELAY=4.0

# Mock mode (set to true for testing without API calls)
MOCK_MODE=false
# RAG store — directory where concall transcripts + embeddings are persisted
# In Docker this is mounted as a volume (/rag_data). Locally, defaults to ./concall_rag
RAG_STORE_DIR=./concall_rag
